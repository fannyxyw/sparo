  "git.ignoreLimitWarning": true,
  // clangd 配置 - 支持代码跳转和智能提示
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}",
    "--all-scopes-completion",
    "--background-index",
    "--clang-tidy",
    "--completion-parse=auto",
    "--completion-style=detailed",
    "--limit-results=100",
    "--enable-config",
    "--fallback-style=LLVM",
    "--function-arg-placeholders=false",
    "--header-insertion-decorators",
    "--header-insertion=iwyu",
    "--pch-storage=memory",
    "--pretty",
    "--ranking-model=decision_forest",
    "-j=12",
    // 启用交叉引用以支持跳转
    "--cross-file-references"
  ],
  "clangd.onConfigChanged": "restart",
  // GN 文件路径解析支持
  "files.associations": {
    "*.gn": "python",
    "*.gni": "python"
  },
  // GN 路径跳转配置（使用路径别名）
  "path-intellisense.mappings": {
    "//build": "${workspaceFolder}/src/build",
    "//base": "${workspaceFolder}/src/base",
    "//third-party": "${workspaceFolder}/src/third-party"
  }
}